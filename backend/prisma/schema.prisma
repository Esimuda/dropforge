// Dropforge — Prisma schema
//
// Postgres (Supabase). UUID primary keys, soft delete via deletedAt, audit
// timestamps via createdAt / updatedAt, and a separate WhitelistSlot table
// so whitelist grants carry an audit trail (who granted, when, current status).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum RewardType {
  AIRDROP
  WHITELIST
  BOTH
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  ENDED
  CANCELLED
}

enum TaskType {
  TWITTER_FOLLOW
  TWITTER_RETWEET
  DISCORD_JOIN
  TOKEN_HOLD
  NFT_HOLD
  SCREENSHOT
  MANUAL
}

enum ProofType {
  AUTO
  MANUAL
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WhitelistStatus {
  GRANTED
  REVOKED
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String?   @unique
  username      String?   @unique
  avatarUrl     String?
  twitterHandle String?   @unique
  twitterId     String?   @unique
  discordHandle String?
  discordId     String?   @unique
  walletAddress String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  refreshTokens        RefreshToken[]
  ownedProject         Project?
  campaignParticipants CampaignParticipant[]
  submissions          Submission[]
  walletEntries        WalletEntry[]
  notifications        Notification[]
  exportLogs           ExportLog[]
  whitelistSlots       WhitelistSlot[]       @relation("WhitelistSlotUser")
  whitelistGrants      WhitelistSlot[]       @relation("WhitelistSlotGranter")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  jti       String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id            String    @id @default(uuid())
  ownerId       String    @unique
  name          String
  logoUrl       String?
  bannerUrl     String?
  website       String?
  twitterHandle String?
  discordInvite String?
  description   String?
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  campaigns Campaign[]
}

model Campaign {
  id              String         @id @default(uuid())
  projectId       String
  title           String
  description     String
  bannerUrl       String?
  // Free-form string per spec (e.g. "ETH", "SOL", "BNB", "MATIC", "BASE", "ARB", "AVAX").
  // Validated at the application layer — see CHAIN_VALUES in src/common/chains.ts.
  chain           String
  rewardType      RewardType
  status          CampaignStatus @default(DRAFT)
  startDate       DateTime
  endDate         DateTime
  maxParticipants Int?
  // Sum of all task points, computed on create / when tasks change.
  totalPoints     Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  project        Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks          Task[]
  participants   CampaignParticipant[]
  submissions    Submission[]          @relation("CampaignSubmissions")
  walletEntries  WalletEntry[]
  whitelistSlots WhitelistSlot[]
  notifications  Notification[]
  exportLogs     ExportLog[]

  @@index([projectId])
  @@index([status, endDate])
  @@index([chain])
  @@index([status, chain, rewardType])
  @@index([deletedAt])
}

model Task {
  id          String    @id @default(uuid())
  campaignId  String
  title       String
  description String?
  taskType    TaskType
  proofType   ProofType
  points      Int       @default(0)
  isRequired  Boolean   @default(true)
  order       Int       @default(0)
  // { targetHandle, tweetId, guildId, contractAddress, minAmount, chain, ... }
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now())

  campaign    Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([campaignId])
}

model CampaignParticipant {
  id             String   @id @default(uuid())
  campaignId     String
  userId         String
  pointsEarned   Int      @default(0)
  tasksCompleted Int      @default(0)
  isEligible     Boolean  @default(false)
  joinedAt       DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([campaignId])
  @@index([userId])
  // Leaderboard: top participants per campaign.
  @@index([campaignId, pointsEarned(sort: Desc)])
}

model Submission {
  id            String           @id @default(uuid())
  taskId        String
  userId        String
  campaignId    String
  proofUrl      String?
  proofText     String?
  tweetUrl      String?
  screenshotUrl String?
  status        SubmissionStatus @default(PENDING)
  reviewNote    String?
  submittedAt   DateTime         @default(now())
  reviewedAt    DateTime?

  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation("CampaignSubmissions", fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([status])
  @@index([taskId, status])
  @@index([campaignId])
}

model WalletEntry {
  id                     String   @id @default(uuid())
  campaignId             String
  userId                 String
  // AES-256-GCM ciphertext. The encryption helper packs iv + ciphertext + authTag
  // into one base64 blob; `iv` is kept here as an explicit column too so the
  // schema matches the spec literally and so external decryption tools can find it.
  encryptedWalletAddress String
  iv                     String
  chain                  String
  submittedAt            DateTime @default(now())
  updatedAt              DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([userId])
}

model WhitelistSlot {
  id         String          @id @default(uuid())
  campaignId String
  userId     String
  grantedBy  String
  grantedAt  DateTime        @default(now())
  status     WhitelistStatus @default(GRANTED)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation("WhitelistSlotUser", fields: [userId], references: [id], onDelete: Cascade)
  granter  User     @relation("WhitelistSlotGranter", fields: [grantedBy], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([campaignId])
  @@index([userId])
}

model Notification {
  id                String   @id @default(uuid())
  userId            String
  type              String
  message           String
  isRead            Boolean  @default(false)
  relatedCampaignId String?
  relatedTaskId     String?
  createdAt         DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [relatedCampaignId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
}

model ExportLog {
  id          String   @id @default(uuid())
  campaignId  String
  exportedBy  String
  format      String
  filters     Json
  recordCount Int      @default(0)
  exportedAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  exporter User     @relation(fields: [exportedBy], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([exportedBy])
}
