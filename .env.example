# Copy to .env.local and fill in.
# For Vercel: paste these same keys into the project's Environment Variables.

# Set true to skip backend and render bundled mock data.
NEXT_PUBLIC_USE_MOCK=true

# Backend base URL (ignored when NEXT_PUBLIC_USE_MOCK=true).
NEXT_PUBLIC_API_URL=http://localhost:3001

# NextAuth — required in production.
NEXTAUTH_URL=http://localhost:8080
NEXTAUTH_SECRET=

# OAuth providers — sign-in buttons are hidden if these are blank.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# WalletConnect — get a project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
